<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CryoPod.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CryoPod"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="CryoPod">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Loaded="RootGrid_Loaded">
        <GridView x:Name="GamesGridView"
                  Margin="24"
                  Padding="8"
                  Loaded="GamesGridView_Loaded"
                  SizeChanged="GamesGridView_SizeChanged"
                  ContainerContentChanging="GamesGridView_ContainerContentChanging"
                  IsItemClickEnabled="True"
                  ItemClick="GamesGridView_ItemClick"
                  IsTabStop="True"
                  SelectionMode="None"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.HorizontalScrollMode="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Hidden"
                  ScrollViewer.VerticalScrollMode="Enabled">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="8" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="UseSystemFocusVisuals" Value="False" />
                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Setter.Value>
                    </Setter>
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Grid RowSpacing="8"
                          HorizontalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="203" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Border x:Name="FocusGlowBorder"
                                    Margin="-8"
                                    CornerRadius="14"
                                    BorderThickness="2"
                                    BorderBrush="#FF7AC7FF"
                                    Background="#167AC7FF"
                                    Opacity="0"
                                    IsHitTestVisible="False" />
                            <Border CornerRadius="8"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                <Image Source="{Binding Thumbnail}"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Stretch="UniformToFill" />
                            </Border>
                        </Grid>
                        <TextBlock x:Name="GameNameTextBlock"
                                   Grid.Row="1"
                                   Text="{Binding Name}"
                                   HorizontalAlignment="Stretch"
                                   TextAlignment="Center"
                                   TextWrapping="WrapWholeWords"
                                   MaxLines="2"
                                   Opacity="0.82" />
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <Grid x:Name="ExitPromptOverlay"
              Background="#99000000"
              Visibility="Collapsed">
            <Border Width="420"
                    Padding="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="16"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                <StackPanel Spacing="20">
                    <TextBlock Text="Do you want to quit?"
                               FontSize="24"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="16">
                        <Button x:Name="ExitPromptYesButton"
                                MinWidth="120"
                                Click="ExitPromptYesButton_Click"
                                Content="Yes" />
                        <Button x:Name="ExitPromptNoButton"
                                MinWidth="120"
                                Click="ExitPromptNoButton_Click"
                                Content="No" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="GameDetailsOverlay"
              Visibility="Collapsed">
            <Image x:Name="GameDetailsBackgroundImage"
                   Stretch="UniformToFill" />
            <Rectangle Fill="#66000000" />
            <Button x:Name="GameDetailsBackButton"
                    Margin="24"
                    Padding="18,10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Click="GameDetailsBackButton_Click"
                    Content="← Back"
                    Style="{ThemeResource AccentButtonStyle}" />
        </Grid>

        <Grid x:Name="StartupLoaderPanel"
              Background="Transparent"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
                <ProgressRing Width="72"
                              Height="72"
                              IsActive="True"
                              HorizontalAlignment="Center" />
                <ProgressBar x:Name="StartupProgressBar"
                             Width="320"
                             Minimum="0"
                             Maximum="1"
                             Value="0"
                             IsIndeterminate="True" />
                <TextBlock x:Name="StartupStatusText"
                           HorizontalAlignment="Center"
                           Text="Searching for installed games..." />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
